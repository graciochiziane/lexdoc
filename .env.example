# ═══════════════════════════════════════════════════════════════
# LEXDOC — Variáveis de Ambiente para Produção (Vercel)
# Copie este ficheiro para o painel de Settings > Environment Variables no Vercel
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────
# DATABASE — Supabase PostgreSQL
# ─────────────────────────────────────────
# PgBouncer (porta 6543) — usado pelo Prisma em runtime (Vercel serverless):
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Conexão directa (porta 5432) — usado pelo Prisma para migrations (prisma db push/migrate):
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres"

# Caracteres especiais na password devem ser URL-encoded (ex: # → %23)

# ─────────────────────────────────────────
# AUTH — JWT Tokens
# ─────────────────────────────────────────
# Gere strings seguras (mínimo 32 caracteres cada):
# Pode usar: openssl rand -base64 48
JWT_SECRET="cole-aqui-uma-string-aleatoria-minimo-32-caracteres-xxxxxxxxxxxx"
JWT_REFRESH_SECRET="cole-aqui-outra-string-aleatoria-minimo-32-caracteres-yyyyyyy"

# Expiração dos tokens (opcional — valores padrão mostrados)
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─────────────────────────────────────────
# AI — Google Gemini 3.1 Flash
# ─────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSy..."

# Modelo a usar (opcional — padrão abaixo)
GEMINI_MODEL="gemini-2.5-flash-preview-05-20"

# Max tokens para respostas (opcional — padrão: 8192)
GEMINI_MAX_TOKENS="8192"
